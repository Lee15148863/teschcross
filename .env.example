DBCon=<your_mongodb_connection_string>
ADMIN_TOKEN=<your_admin_token>
PORT=8080

# Inventory & Till System
INV_JWT_SECRET=<your_jwt_secret_key>
INV_AUDIT_KEY=<your_audit_encryption_key>

# StoreFlow SaaS
SAAS_JWT_SECRET=<your_saas_jwt_secret>
# Production gate: set to 'true' to allow signups without MongoDB URI (dev/test only)
# Default (unset/false) rejects legacy signups, enforcing customer-owned Atlas requirement.
# PRODUCTION MUST BE false OR UNCOMMENTED.
ALLOW_LEGACY_SIGNUP=false

# StoreFlow dry-run flags — keep true until real GCP customer deployment is ready.
# GCP_ADMIN_DRY_RUN=true → gcp-admin.js returns mock responses, no real Cloud Build calls.
# SECRET_MANAGER_DRY_RUN=true → gcp-secret-manager.js returns mock responses, no real Secret Manager.
# DRY_RUN=true → enables all dry-run modes at once.
GCP_ADMIN_DRY_RUN=true
SECRET_MANAGER_DRY_RUN=true

# CAPTCHA signing secret (HMAC for math CAPTCHA tokens; defaults to SAAS_JWT_SECRET+'_captcha')
CAPTCHA_SECRET=<your-captcha-secret>

# SMTP (for VAT Invoice email)
SMTP_HOST=<smtp_host>
SMTP_PORT=587
SMTP_USER=<smtp_username>
SMTP_PASS=<smtp_password>
SMTP_FROM=<sender_email>
